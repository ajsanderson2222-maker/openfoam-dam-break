FoamFile
{
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Domain matches Koshizuka & Oka (1996) exactly: 1.0m x 0.6m tank
// a = 0.146m → L/a = 6.849, H/a = 4.11
// Column: a wide x 2a tall, initially at left wall

convertToMeters 0.146;

vertices
(
    (0 0 0)         // 0
    (6.849 0 0)     // 1
    (6.849 4.11 0)  // 2
    (0 4.11 0)      // 3
    (0 0 0.1)       // 4
    (6.849 0 0.1)   // 5
    (6.849 4.11 0.1)// 6
    (0 4.11 0.1)    // 7
);

blocks
(
    // Coarse: 68x41  (~10 cells/a)
    hex (0 1 2 3 4 5 6 7) (68 41 1) simpleGrading (1 1 1)
);

defaultPatch
{
    type symmetry;
}

boundary
(
    leftWall
    {
        type wall;
        faces ( (0 3 7 4) );
    }
    rightWall
    {
        type wall;
        faces ( (1 5 6 2) );
    }
    lowerWall
    {
        type wall;
        faces ( (0 4 5 1) );
    }
    atmosphere
    {
        type patch;
        faces ( (3 2 6 7) );
    }
);

