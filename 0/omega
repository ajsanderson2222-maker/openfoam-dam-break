FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 1.0;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    wall
    {
        type            omegaWallFunction;
        value           uniform 1.0;
    }

    atmosphere
    {
        type            inletOutlet;
        inletValue      uniform 1.0;
        value           uniform 1.0;
    }
}

